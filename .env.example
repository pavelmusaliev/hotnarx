# Скопируйте этот файл в .env и заполните свои значения

# 1. Токен бота — получить у @BotFather командой /newbot
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# 2. Ваш Telegram ID — узнать у @userinfobot (просто напишите ему /start)
ADMIN_ID=123456789

# 3. ID или username вашего канала
#    Если канал публичный: @moy_kanal
#    Если приватный: -1001234567890 (добавьте бота в канал как администратора!)
CHANNEL_ID=@moy_kanal

# 4. Минимальная скидка для отображения (в процентах)
MIN_DISCOUNT=30

# 5. Как часто проверять акции (в часах)
CHECK_HOURS=3
